@model Repositories.Models.ViewModels.Workspace.WorkspaceVM

@{
    ViewData["Title"] = "Workspace";
}

<style>

    /*==========================
        Workspace Page
    ==========================*/

    .workspace-page{

        display:flex;

        flex-direction:column;

        gap:20px;

        height:100%;

    }

    .workspace-header{

        display:flex;

        align-items:center;

        justify-content:space-between;

        gap:16px;

        flex-wrap:wrap;

    }

    .workspace-header h3{

        font-family:var(--font-display);

        font-size:24px;

        font-weight:800;

        letter-spacing:-.02em;

        color:var(--text-dark);

        display:flex;

        align-items:center;

        gap:10px;

    }

    .workspace-header h3 .k-icon{

        font-size:22px;

        color:var(--brand-1);

    }

    .workspace-header .text-muted{

        font-size:14px;

        color:var(--text-light);

    }

    #btnNewGroup{

        border:none;

        cursor:pointer;

    }


    /*==========================
        Splitter Shell
    ==========================*/

    #workspaceSplitter{

        flex:1;

        min-height:0;

        border-radius:var(--radius-md) !important;

        border:1px solid var(--border-color) !important;

        box-shadow:var(--shadow-sm);

        overflow:hidden;

    }

    #workspaceSplitter.k-splitter{

        background:var(--card-bg);

    }

    #workspaceSplitter .k-pane{

        background:var(--card-bg);

        display:flex;

        flex-direction:column;

    }

    #workspaceSplitter > .k-pane:not(:last-child){

        border-right:1px solid var(--border-color);

    }

    /* Kendo splitbar — thin, brand-tinted on hover instead of the default gray grip */
    #workspaceSplitter .k-splitbar{

        background:var(--border-color);

        border:none;

        transition:background .18s ease;

    }

    #workspaceSplitter .k-splitbar:hover,
    #workspaceSplitter .k-splitbar-horizontal-hover{

        background:var(--brand-1);

    }

    #workspaceSplitter .k-splitbar .k-resize-handle{

        background:transparent;

    }


    /*==========================
        Panel Header / Body
    ==========================*/

    .panel-header{

        padding:14px 18px;

        border-bottom:1px solid var(--border-color);

        background:#fbfbfe;

        flex:none;

        display:flex;

        align-items:center;

        justify-content:space-between;

        gap:10px;

    }

    .panel-header h5{

        margin:0;

        font-size:13px;

        font-weight:700;

        letter-spacing:.05em;

        text-transform:uppercase;

        color:var(--text-light);

        display:flex;

        align-items:center;

        gap:8px;

        white-space:nowrap;

        overflow:hidden;

        text-overflow:ellipsis;
    }

    .panel-header h5 .crumb-name{

        color:var(--brand-1);

        text-transform:none;

        letter-spacing:0;

        font-weight:700;

    }

    .panel-header .k-badge{

        font-size:11px;

    }

    .panel-body{

        flex:1;

        min-height:0;

        overflow:auto;

        padding:16px 18px;

        display:flex;

        flex-direction:column;

    }

    .panel-body.no-scroll{

        overflow:hidden;

    }

    .panel-body hr{

        border:none;

        border-top:1px solid var(--border-color);

        margin:14px 0;

        flex:none;

    }


    /*==========================
        Group Search
    ==========================*/

    #groupSearch{

        width:100%;

    }

    #groupSearch .k-input-inner{

        border-radius:var(--radius-pill) !important;

    }


    /*==========================
        Group List
    ==========================*/

    #groupList{

        display:flex;

        flex-direction:column;

        gap:6px;

        overflow:auto;

        min-height:0;

    }

    .group-card{

        display:flex;

        align-items:center;

        gap:12px;

        padding:11px 14px;

        border-radius:var(--radius-sm);

        font-size:14px;

        font-weight:500;

        color:var(--text-dark);

        cursor:pointer;

        border:1px solid transparent;

        transition:var(--transition);

    }

    .group-card:hover{

        background:var(--accent-soft);

        border-color:rgba(79,70,229,.15);

    }

    .group-card.active{

        background:linear-gradient(135deg, var(--brand-1), var(--brand-3));

        color:#fff;

        box-shadow:0 8px 18px rgba(79,70,229,.28);

    }

    .group-card .k-icon{

        font-size:17px;

        color:var(--brand-1);

    }

    .group-card.active .k-icon{

        color:#fff;

    }


    /*==========================
        Folder Toolbar
    ==========================*/

    #folderToolbar{

        display:flex;

        gap:10px;

        flex-wrap:wrap;

        flex:none;

    }

    #folderToolbar .k-searchbox{

        margin-left:auto;

        width:220px;

    }


    /*==========================
        Empty States
    ==========================*/

    .empty-panel{

        flex:1;

        display:flex;

        flex-direction:column;

        align-items:center;

        justify-content:center;

        gap:10px;

        text-align:center;

        padding:30px 16px;

        color:var(--text-faint);

    }

    .empty-panel .k-icon{

        font-size:36px;

        color:rgba(79,70,229,.25);

    }

    .empty-panel p{

        margin:0;

        font-size:13.5px;

        font-weight:500;

    }

    .empty-panel span.hint{

        font-size:12px;

        color:var(--text-faint);

        font-weight:400;
    }


    /*==========================
        Folder Tree
    ==========================*/

    #folderTree{

        flex:1;

        min-height:0;

        display:flex;

        flex-direction:column;

    }

    #folderTree .k-treeview{

        overflow:auto;

        flex:1;

        min-height:0;

    }

    #folderTree .k-treeview-item{

        border-radius:var(--radius-sm);

    }

    #folderTree .k-treeview-leaf{

        padding:7px 8px;

        border-radius:var(--radius-sm);

        font-size:13.5px;

        font-weight:500;

        color:var(--text-dark);

        transition:var(--transition);

    }

    #folderTree .k-treeview-leaf:hover{

        background:var(--accent-soft);

    }

    #folderTree .k-treeview-leaf.k-selected,
    #folderTree .k-treeview-leaf.k-selected:hover{

        background:linear-gradient(135deg, var(--brand-1), var(--brand-3));

        color:#fff;

    }

    #folderTree .k-treeview-leaf.k-selected .k-icon,
    #folderTree .k-treeview-leaf.k-selected .node-count{

        color:#fff;

    }

    #folderTree .node-icon{

        font-size:16px;

        color:var(--brand-1);

        margin-right:2px;
    }

    #folderTree .node-count{

        margin-left:auto;

        font-size:11px;

        color:var(--text-faint);

        font-weight:600;

    }

    #folderTree .k-treeview-leaf .k-treeview-leaf-text{

        display:flex;

        align-items:center;

        gap:6px;

        width:100%;

    }


    /*==========================
        Content Grid
    ==========================*/

    #contentGrid{

        flex:1;

        min-height:0;

        display:flex;

        flex-direction:column;

        overflow:hidden;

    }

    #contentGrid .k-grid{

        flex:1;

        height:100%;

    }

 
#contentGrid .k-grid-header{
    overflow:hidden !important;
}

#contentGrid .k-grid-header-wrap{
    overflow:hidden !important;
}

#contentGrid .k-grid-content{
    overflow:auto !important;
}



    #contentGrid .k-grid-header{

        background:#fbfbfe;

    }

    #contentGrid .k-grid-header th{

        font-size:12px;

        font-weight:700;

        letter-spacing:.03em;

        text-transform:uppercase;

        color:var(--text-light);

    }

    #contentGrid .k-grid-content td{

        font-size:13.5px;

        color:var(--text-dark);

        vertical-align:middle;

    }

    #contentGrid .k-grid-content tr{

        transition:var(--transition);

    }

    #contentGrid .k-grid-content tr:hover{

        background:var(--accent-soft);

    }

    #contentGrid .k-grid-content tr.k-selected td{

        background:rgba(79,70,229,.08);

    }
 

    #contentGrid .k-grid td,
    #contentGrid .k-grid th{

        white-space:nowrap;

    }

    .row-name{

        display:flex;

        align-items:center;

        gap:10px;

        font-weight:600;

    }

    .row-name .k-icon{

        font-size:18px;

    }

    .row-name .k-icon.type-folder{

        color:var(--brand-1);

    }

    .row-name .k-icon.type-file{

        color:#9aa1b1;

    }

    .type-badge{

        display:inline-flex;

        align-items:center;

        padding:3px 10px;

        border-radius:var(--radius-pill);

        font-size:11.5px;

        font-weight:700;

        letter-spacing:.02em;

        text-transform:capitalize;

    }

    .type-badge.folder{

        background:rgba(79,70,229,.12);

        color:var(--brand-1);

    }

    .type-badge.file{

        background:rgba(154,161,177,.16);

        color:#6b7280;

    }

    .row-path{

        color:var(--text-light);

        font-size:12.5px;

    }

    .row-actions-btn{

        border-radius:50% !important;

        width:32px;

        height:32px;

        padding:0 !important;

        color:var(--text-light);

    }

    .row-actions-btn:hover{

        background:var(--accent-soft) !important;

        color:var(--brand-1);

    }


    /*==========================
        Actions Popup Menu
    ==========================*/

    .actions-menu{

        display:none;

        min-width:220px;

        background:var(--card-bg);

        border:1px solid var(--border-color);

        border-radius:var(--radius-md);

        box-shadow:0 12px 28px rgba(20,20,43,.16);

        padding:6px;

        z-index:10001;

    }

    .actions-menu ul{

        list-style:none;

        margin:0;

        padding:0;

        display:flex;

        flex-direction:column;

        gap:2px;

    }

    .actions-menu li{

        display:flex;

        align-items:center;

        gap:10px;

        padding:9px 12px;

        border-radius:var(--radius-sm);

        font-size:13.5px;

        font-weight:500;

        color:var(--text-dark);

        cursor:pointer;

        transition:var(--transition);

    }

    .actions-menu li:hover{

        background:var(--accent-soft);

        color:var(--brand-1);

    }

    .actions-menu li .k-icon{

        font-size:16px;

        color:var(--text-light);

        width:18px;

        text-align:center;

    }

    .actions-menu li:hover .k-icon{

        color:var(--brand-1);

    }

    .actions-menu li.danger{

        color:#dc2626;

    }

    .actions-menu li.danger .k-icon{

        color:#dc2626;

    }

    .actions-menu li.danger:hover{

        background:rgba(220,38,38,.08);

        color:#dc2626;

    }

    .actions-menu li.danger:hover .k-icon{

        color:#dc2626;

    }

    .actions-menu .menu-divider{

        height:1px;

        background:var(--border-color);

        margin:5px 4px;

        padding:0;

        cursor:default;

    }

    .actions-menu .menu-divider:hover{

        background:var(--border-color);

    }

    .move-dialog {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .move-grid {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) minmax(320px, 1.2fr);
        gap: 16px;
    }

    .move-card {
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        background: var(--card-bg);
        padding: 14px;
        min-height: 360px;
    }

    .move-card h6 {
        margin: 0 0 6px;
        font-weight: 800;
        color: var(--text-dark);
    }

    .move-help,
    .move-empty {
        color: var(--text-light);
        font-size: 13px;
        margin-bottom: 12px;
    }

    #moveDestinationTree {
        max-height: 420px;
        overflow: auto;
    }

    .move-options {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin: 12px 0;
    }

    .move-option {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 10px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        background: rgba(248,250,252,.85);
        cursor: pointer;
        font-size: 13px;
        font-weight: 650;
    }

    .move-option input {
        accent-color: var(--brand-1);
    }

    .move-analysis {
        border-top: 1px solid var(--border-color);
        padding-top: 12px;
        margin-top: 12px;
        max-height: 250px;
        overflow: auto;
    }

    .move-analysis-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .move-role-list {
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        padding: 10px;
        min-height: 86px;
    }

    .move-role-list strong {
        display: block;
        margin-bottom: 7px;
        font-size: 12px;
        color: var(--text-light);
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .move-role-pill {
        display: inline-flex;
        margin: 0 5px 6px 0;
        padding: 3px 8px;
        border-radius: var(--radius-pill);
        background: rgba(79,70,229,.12);
        color: var(--brand-1);
        font-size: 12px;
        font-weight: 700;
    }

    .move-role-pill.removed {
        background: rgba(239,68,68,.12);
        color: #b91c1c;
    }

    .move-stats {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin: 10px 0;
        color: var(--text-light);
        font-size: 13px;
    }

    .move-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .k-treeview .move-node-disabled {
        opacity: .45;
        pointer-events: none;
    }

    .move-tree-node {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 2px 6px;
        border-radius: var(--radius-sm);
    }

    .move-tree-node.group {
        background: rgba(79,70,229,.13);
        color: var(--brand-1);
        font-weight: 800;
    }

    .move-tree-node.folder {
        color: var(--text-dark);
    }

    .move-option-note {
        display: inline-flex;
        margin: 4px 0 10px;
        padding: 5px 9px;
        border-radius: var(--radius-pill);
        background: rgba(14,165,233,.11);
        color: #0369a1;
        font-size: 12px;
        font-weight: 700;
    }


    /*==========================
        Responsive
    ==========================*/

    @@media (max-width:768px){

        .workspace-header{

            align-items:flex-start;

        }

        #folderToolbar .k-searchbox{

            margin-left:0;

            width:100%;

        }

    }

    .group-card{

    display:flex;

    justify-content:space-between;

    align-items:center;

}

.group-left{

    display:flex;

    align-items:center;

    gap:12px;

    flex:1;

}

.group-action-btn{

    width:30px;

    height:30px;

    border:none;

    background:transparent;

    border-radius:50%;

    cursor:pointer;

    display:flex;

    align-items:center;

    justify-content:center;

    color:inherit;

}

.group-action-btn:hover{

    background:rgba(255,255,255,.15);

}

.group-card:not(.active) .group-action-btn:hover{

    background:var(--accent-soft);

}

</style>

<div class="workspace-page">

    <div class="workspace-header">

        <div>
            <h3 class="mb-1"><span class="k-icon k-font-icon k-i-folder"></span> Workspace</h3>
            <span class="text-muted">
                Organize your groups, folders and documents.
            </span>
        </div>

        <button id="btnNewGroup">
            <span class="k-icon k-i-plus"></span> New Group
        </button>

    </div>

    <div id="workspaceSplitter">

        <!-- ===================== GROUPS ===================== -->

        <div>

            <div class="panel-header">

                <h5><span class="k-icon k-font-icon k-i-menu"></span> Groups</h5>

            </div>

            <div class="panel-body">

                <input id="groupSearch" />

                <hr />

                @if (Model.Groups.Any())
                {
                    <div id="groupList">

                        @foreach (var group in Model.Groups)
                        {
                            <div class="group-card"
     data-id="@group.GroupId">

    <div class="group-left">

        <span class="k-icon k-font-icon k-i-folder"></span>

        <span>@group.GroupName</span>

    </div>

    <button class="group-action-btn"
            data-id="@group.GroupId"
            data-name="@group.GroupName">

        <span class="k-icon k-i-more-vertical"></span>

    </button>

</div>
                        }

                    </div>
                }
                else
                {
                    <div class="empty-panel">

                        <span class="k-icon k-font-icon k-i-folder-open"></span>

                        <p>No groups found.</p>
                        <span class="hint">Create a group to get started.</span>

                    </div>
                }

            </div>

        </div>

        <!-- ===================== TREE ===================== -->

        <div>

            <div class="panel-header">

                <h5><span class="k-icon k-font-icon k-i-treeview"></span> Folder Tree</h5>

            </div>

            <div class="panel-body no-scroll">

                <div id="folderTree">

                    <div class="empty-panel">

                        <span class="k-icon k-font-icon k-i-treeview"></span>

                        <p>Select a group to load folders.</p>

                    </div>

                </div>

            </div>

        </div>

        <!-- ===================== CONTENT ===================== -->

        <div>

            <div class="panel-header">

                <h5 id="contentPanelTitle"><span class="k-icon k-font-icon k-i-grid-layout"></span> Folder Contents</h5>

            </div>

            <div class="panel-body no-scroll">

                <div id="folderToolbar">

                    <button id="btnNewFolder">
                        <span class="k-icon k-i-folder-add"></span> New Folder
                    </button>

                    <button id="btnUpload">
                        <span class="k-icon k-i-upload"></span> Upload
                    </button>

                    <button id="btnRefresh">
                        <span class="k-icon k-i-reload"></span> Refresh
                    </button>

                </div>

                <hr />

                <div id="contentGrid"></div>

            </div>

        </div>

    </div>

</div>

<!-- Shared actions popup, reused for every grid row -->
<div id="actionsPopup" class="actions-menu">
    <ul>
        <li data-type="folder" data-action="addChild"><span class="k-icon k-i-folder-add"></span> Create Child Folder</li>
        <li data-type="folder" data-action="upload"><span class="k-icon k-i-upload"></span> Upload File</li>
        <li data-type="folder" class="menu-divider"></li>
        <li data-type="folder" data-action="rename"><span class="k-icon k-i-edit"></span> Rename Folder</li>
        <li data-type="folder" data-action="move"><span class="k-icon k-i-folder-up"></span> Move Folder</li>
        <li data-type="folder" data-action="copy"><span class="k-icon k-i-copy"></span> Copy Folder</li>
        <li data-type="folder" data-action="download"><span class="k-icon k-i-download"></span> Download as ZIP</li>
        <li data-type="folder" class="menu-divider"></li>
        <li data-type="folder" data-action="share"><span class="k-icon k-i-share"></span> Share / Permissions</li>
        <li data-type="folder" data-action="favorite"><span class="k-icon k-i-star-outline"></span> Add to Favorites</li>
        <li data-type="folder" data-action="details"><span class="k-icon k-i-information"></span> Properties</li>
        <li data-type="folder" class="menu-divider"></li>
        <li data-type="folder" data-action="trash" class="danger"><span class="k-icon k-i-trash"></span> Move to Trash</li>
        <li data-type="file" data-action="preview"><span class="k-icon k-i-eye"></span> Preview</li>
        <li data-type="file" data-action="download"><span class="k-icon k-i-download"></span> Download</li>
        <li data-type="file" class="menu-divider"></li>
        <li data-type="file" data-action="rename"><span class="k-icon k-i-edit"></span> Rename File</li>
        <li data-type="file" data-action="move"><span class="k-icon k-i-folder-up"></span> Move File</li>
        <li data-type="file" data-action="copy"><span class="k-icon k-i-copy"></span> Copy File</li>
        <li data-type="file" class="menu-divider"></li>
        <li data-type="file" data-action="versions"><span class="k-icon k-i-track-changes"></span> Version History</li>
        <li data-type="file" data-action="share"><span class="k-icon k-i-share"></span> Share / Permissions</li>
        <li data-type="file" data-action="favorite"><span class="k-icon k-i-star-outline"></span> Add to Favorites</li>
        <li data-type="file" data-action="details"><span class="k-icon k-i-information"></span> Properties</li>
        <li data-type="file" class="menu-divider"></li>
        <li data-type="file" data-action="trash" class="danger"><span class="k-icon k-i-trash"></span> Move to Trash</li>
    </ul>
</div>
<div id="groupActionsPopup" class="actions-menu">

    <ul>

        <li data-action="info">

            <span class="k-icon k-i-information"></span>

            Information

        </li>

        <li data-action="edit">

            <span class="k-icon k-i-edit"></span>

            Update

        </li>

        <li class="menu-divider"></li>

        <li data-action="delete"
            class="danger">

            <span class="k-icon k-i-trash"></span>

            Move to Trash

        </li>

    </ul>

</div>
<div id="folderWindow" style="display:none;">

    @await Html.PartialAsync("_CreateFolder", Model)

</div>
<div id="uploadFileWindow" style="display:none;">

    @await Html.PartialAsync("_UploadFile", Model)

</div>

<div id="moveWindow" style="display:none;">
    <div class="move-dialog">
        <div class="move-grid">
            <section class="move-card">
                <h6>Destination</h6>
                <p class="move-help">Select a group root or folder. Files must be moved into a folder.</p>
                <div id="moveDestinationTree"></div>
            </section>

            <section class="move-card">
                <h6>Permission handling</h6>
                <div id="moveSelectionSummary" class="move-help">Choose a destination to preview permissions.</div>

                <div id="movePermissionOptions" class="move-options">
                    <label class="move-option same-group-option">
                        <input type="radio" name="MovePermissionOption" value="keep" checked />
                        <span>Keep existing permissions</span>
                    </label>
                    <label class="move-option same-group-option cross-group-option">
                        <input type="radio" name="MovePermissionOption" value="inherit" />
                        <span>Inherit destination permissions</span>
                    </label>
                    <label class="move-option cross-group-option">
                        <input type="radio" name="MovePermissionOption" value="removeUnavailable" />
                        <span>Remove unavailable role permissions</span>
                    </label>
                    <label class="move-option cross-group-option">
