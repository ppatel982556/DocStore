/*==========================
    Helpers
==========================*/



function promptForName(title, label, onConfirm) {
    var win = $("<div/>").kendoWindow({
        title: title,
        modal: true,
        resizable: false,
        width: "360px",
        visible: false,
        close: function () { win.destroy(); }
    }).data("kendoWindow");

    var $content = $(
        '<div style="padding:4px 2px 8px;">' +
            '<label style="font-size:12.5px;font-weight:600;color:var(--text-light);display:block;margin-bottom:6px;">' + label + '</label>' +
            '<input id="promptInput" style="width:100%;" />' +
            '<div style="display:flex;justify-content:flex-end;gap:8px;margin-top:18px;">' +
                '<button id="promptCancel" class="k-button">Cancel</button>' +
                '<button id="promptOk" class="k-button k-button-solid-primary">Confirm</button>' +
            '</div>' +
        '</div>');

    win.content($content);
    win.center().open();

    $content.find("#promptInput").kendoTextBox({ placeholder: label });

    $content.find("#promptCancel").on("click", function () { win.close(); });
    $content.find("#promptOk").on("click", function () {
        var val = $content.find("#promptInput").val();
        if (!val) {
            kendo.alert("Please enter a value.");
            return;
        }
        win.close();
        onConfirm(val);
    });
}

function setContentTitle(name) {
    var $title = $("#contentPanelTitle");

    var parts = [
        '<span class="k-icon k-font-icon k-i-grid-layout"></span>',
        '<a href="#" class="content-crumb" data-folder-id="">Folder Contents</a>'
    ];

    getContentBreadcrumbs().forEach(function (crumb) {
        parts.push('&nbsp;/&nbsp;');
        parts.push(
            '<a href="#" class="content-crumb" data-folder-id="' + crumb.id + '">' +
            kendo.htmlEncode(crumb.name) +
            '</a>'
        );
    });

    $title.html(parts.join(" "));
}

function getContentBreadcrumbs() {
    if (!currentFolderId) {
        return [];
    }

    var crumbs = [];
    var node = findTreeNode(currentFolderId);

    if (node && treeviewWidget) {
        var currentNode = treeviewWidget.dataItem(node);

        while (currentNode) {
            crumbs.unshift({
                id: currentNode.id,
                name: currentNode.text
            });
            currentNode = currentNode.parentNode();
        }

        return crumbs;
    }

    var pathParts = (currentFolderPath || "/")
        .split("/")
        .filter(function (part) { return !!part; });

    return pathParts.map(function (part, index) {
        return {
            id: index === pathParts.length - 1 ? currentFolderId : "",
            name: part
        };
    });
}

function updateUploadButtonState() {
    var uploadButton = $("#btnUpload").data("kendoButton");
    var canUploadToCurrentSelection = !!currentGroupId && !!currentFolderId;

    if (uploadButton) {
        uploadButton.enable(canUploadToCurrentSelection);
    }
}

function clearGrid(message) {
    var grid = $("#contentGrid").data("kendoGrid");
    if (grid) {
        grid.destroy();
    }
    $("#contentGrid").empty().append(
        '<div class="empty-panel"><span class="k-icon k-font-icon k-i-grid-layout"></span><p>' + message + '</p></div>'
    );
}

/*==========================
    Data loading
==========================*/

function loadFolderContents(groupId, folderId) {

    kendo.ui.progress($("#contentGrid"), true);

    $.ajax({

        url: "/workspace/folder-contents",
        type: "GET",
        data: { groupId: groupId, folderId: folderId },

        success: function (data) {
            buildFolderGrid(data);
        },

        error: function () {
            alert("Unable to load folder contents.");
        },

        complete: function () {
            kendo.ui.progress($("#contentGrid"), false);
        }

    });
}

function loadFolderTree(groupId) {

    kendo.ui.progress($("#folderTree"), true);

    $.ajax({

        url: "/workspace/folders/" + groupId,
        type: "GET",

        success: function (data) {
            buildTree(data);
        },

        error: function () {
            alert("Unable to load folders.");
        },

        complete: function () {
            kendo.ui.progress($("#folderTree"), false);
        }

    });
}

function nodeHasChildren(dataItem) {
    return !!(dataItem && dataItem.items && dataItem.items.length);
}

function activateTreeNode(treeView, node) {
    var dataItem = treeView.dataItem(node);

    if (!dataItem) {
        return;
    }

    currentFolderId = dataItem.id;
    currentFolderName = dataItem.text;
    currentFolderPath = buildFolderPathFromTree(dataItem);
    updateUploadButtonState();

    if (nodeHasChildren(dataItem)) {
        treeView.expand(node);
    }

    setContentTitle(currentFolderName);
    loadFolderContents(currentGroupId, currentFolderId);
}

function buildTree(data) {

var existingTree = $("#folderTree").data("kendoTreeView");

if (existingTree) {
    existingTree.destroy();
}

$("#folderTree").empty();
    var tree = [];
    var lookup = {};

    data.forEach(function (item) {
        lookup[item.id] = {
    id: item.id,
    text: item.text,
    hasChildren: item.hasChildren,
    expanded: false,
    items: []
};
    });

    data.forEach(function (item) {
        if (item.parentId == null) {
            tree.push(lookup[item.id]);
        }
        else if (lookup[item.parentId]) {
            lookup[item.parentId].items.push(lookup[item.id]);
        }
    });

    $("#folderTree").empty();

    treeviewWidget = $("#folderTree").kendoTreeView({

    dataSource: new kendo.data.HierarchicalDataSource({
        data: tree,
        schema: {
            model: {
                id: "id",
                children: "items"
            }
        }
    }),

    dataTextField: "text",

    template:
        '<span class="node-icon k-icon k-font-icon k-i-folder"></span>' +
        '<span>#: item.text #</span>',

    select: function (e) {

    var dataItem = this.dataItem(e.node);

    if (!dataItem)
        return;

    activateTreeNode(this, e.node);

}

}).data("kendoTreeView");

    @* $("#folderTree").off("click.workspaceNode").on("click.workspaceNode", ".k-treeview-leaf", function () {
        var treeView = $("#folderTree").data("kendoTreeView");
        var $leaf = $(this);
        var $node = $leaf.closest(".k-treeview-item");

        if (!treeView || !$node.length) {
            return;
        }

        treeView.select($leaf);
        activateTreeNode(treeView, $node);
    }); *@

}

function buildFolderGrid(data) {

    // Destroy existing grid if present
    var existingGrid = $("#contentGrid").data("kendoGrid");

    if (existingGrid) {
        existingGrid.destroy();
    }

    // ALWAYS clear the container
    $("#contentGrid").empty();

    // Show empty state if there is no data
    if (!data || data.length === 0) {
        if (!currentGroupId) {
            clearGrid("Select any group or folder to view contents. Files can only be uploaded inside a folder.");
        } else if (!currentFolderId) {
            clearGrid("Select any folder to view its contents. Files cannot be uploaded at root level.");
        } else {
            clearGrid("This folder is empty. Upload a file or create a sub-folder to get started.");
        }

        return;
    }

    // Create Grid
    $("#contentGrid").kendoGrid({

        dataSource: {
            data: data,
            pageSize: 20
        },

        height: "100%",

        scrollable: true,

        resizable:true,

        sortable: true,

        pageable: {
            pageSizes: [20, 50, 100],
            refresh: true
        },

        selectable: "row",

change: function () {

        var item = this.dataItem(this.select());

        if (!item)
            return;

        if (item.type === "Folder") {
            currentFolderId = item.id;
            currentFolderName = item.name;
            currentFolderPath = item.path || "/";
            updateUploadButtonState();
        }

    },

        columns: [

            {
                field: "name",
                title: "Name",
                width: 400,
                template: function (item) {

                    return `
                        <div class="row-name">
                            <span class="k-icon ${item.type === "Folder" ? "k-i-folder type-folder" : "k-i-file type-file"}"></span>
                            <span>${item.name}</span>
                        </div>
                    `;
                }
            },

            {
                field: "type",
                title: "Type",
                width: 180,
                template: function (item) {
                    var type = (item.type || "").toLowerCase();
                    var cssClass = type === "folder" ? "folder" : "file";
                    return `<span class="type-badge ${cssClass}">${item.type || "-"}</span>`;
                }
            },

            {
                field: "path",
                title: "Path",
                width: 450,
                template: function (item) {
                    return `<span class="row-path">${item.path || "-"}</span>`;
                }
            },
{
    field: "sizeDisplay",
    title: "Size",
    width: 120
},
{
    field: "createdBy",
    title: "Created By",
    width: 180
},
{
    field: "createdAt",
    title: "Created At",
    width: 180,
    template: function(item) {

        var date = kendo.parseDate(item.createdAt);

        return date
            ? kendo.toString(date, "dd MMM yyyy hh:mm tt")
            : "-";

    }
},
            {
                title: "Actions",
                width: 90,
                template: `
                    <button class="row-actions-btn"
                            data-id="#=id#">
                        <span class="k-icon k-i-more-vertical"></span>
                    </button>
                `
            }

        ]

    });
var grid = $("#contentGrid").data("kendoGrid");

grid.tbody.off("dblclick.workspace").on("dblclick.workspace", "tr", function () {

    var item = grid.dataItem(this);

    if (!item || item.type !== "Folder")
        return;

    openFolderView(
        item.id,
        item.name,
        item.path || "/"
    );
    });
}

/*==========================
    Folder / file actions
==========================*/

function syncActionMenu(itemType) {
    var normalizedType = itemType === "folder" ? "folder" : "file";
    var menuItems = $("#actionsPopup li");

    menuItems.hide();
    menuItems.filter('[data-type="' + normalizedType + '"]').show();

    $("#actionsPopup .menu-divider:visible").each(function () {
        var hasVisibleBefore = $(this).prevAll("li:visible:not(.menu-divider)").first().length > 0;
        var hasVisibleAfter = $(this).nextAll("li:visible:not(.menu-divider)").first().length > 0;

        $(this).toggle(hasVisibleBefore && hasVisibleAfter);
    });
}

function openRootFolderView() {
    currentFolderId = null;
    currentFolderName = null;
    currentFolderPath = "/";
    updateUploadButtonState();
    setContentTitle(null);

    if (treeviewWidget) {
        treeviewWidget.select($());
    }

    $("#folderTree .k-selected").removeClass("k-selected");
    loadFolderContents(currentGroupId, null);
}

function openFolderView(folderId, folderName, folderPath) {
    if (!folderId) {
        openRootFolderView();
        return;
    }

    var node = findTreeNode(folderId);

    if (node && treeviewWidget) {
        activateTreeNode(treeviewWidget, node);
        return;
    }

    currentFolderId = folderId;
    currentFolderName = folderName || null;
    currentFolderPath = folderPath || "/";
    updateUploadButtonState();
    setContentTitle(currentFolderName);
    loadFolderContents(currentGroupId, currentFolderId);
}

function openUploadWindowForFolder(folderId, folderName, folderPath) {
    if (!currentGroupId) {
        showErrorToast("Please select a group.");
        return;
    }

    if (!folderId) {
        showErrorToast("Please select a folder first. Files cannot be uploaded at root level.");
        return;
    }

    currentFolderId = folderId;
    currentFolderName = folderName || currentFolderName;
    currentFolderPath = folderPath || currentFolderPath || "/";

    $("#UploadGroupId").val(currentGroupId);
    $("#UploadFolderId").val(currentFolderId);
    $("#UploadFolderName").val(currentFolderName);
    $("#UploadFolderPath").val(currentFolderPath);
    $("#UploadDescription").val("");
    $("#UploadFile").val("");

    var roleMultiSelect = $("#UploadRoles").data("kendoMultiSelect");
    if (roleMultiSelect) {
        roleMultiSelect.value([]);
    }

    updateUploadButtonState();
    uploadWindow.center().open();
}

function getGridItemById(id) {
    var grid = $("#contentGrid").data("kendoGrid");

    if (!grid) {
        return null;
    }

    return grid.dataSource.data().find(function (entry) {
        return entry.id == id;
    }) || null;
}

function handleWorkspaceAction(action, id, itemType) {
    var normalizedType = itemType === "folder" ? "folder" : "file";
    var item = getGridItemById(id);

    if (!item) {
        kendo.alert(normalizedType === "folder" ? "Folder not found." : "File not found.");
        return;
    }

    switch (action) {
        case "addChild":
            if (normalizedType !== "folder") {
                return;
            }

            openCreateFolderPopup(
                item.id,
                item.name,
                item.path
            );
            break;

        case "upload":
            uploadFileTo(
                item.id,
                item.name,
                item.path
            );
            break;

        case "preview":
            kendo.alert("File preview will be added here.");
            break;

        case "rename":
            if (normalizedType === "folder") {
                editFolder(id);
                return;
            }

            editFile(id);
            break;

        case "move":
            openMoveDialog(id, normalizedType, item);
            break;

        case "copy":
            kendo.alert(normalizedType === "folder"
                ? "Copy Folder will be added here."
                : "Copy File will be added here.");
            break;

        case "download":
            window.location.href = "/workspace/download/" + id;
            break;

        case "versions":
            kendo.alert("Version History will be added here.");
            break;

        case "share":
            kendo.alert("Share / Permissions will be added here.");
            break;

        case "favorite":
            kendo.alert("Add to Favorites will be added here.");
            break;

        case "details":

    if (normalizedType === "folder") {

        showFolderInfo(id);

    }
    else {

        showFileInfo(id);

    }

    break;

        case "trash":
            kendo.confirm("Move this item to Trash?").then(function () {
                if (normalizedType === "folder") {
                    moveToTrash("folder", id);
                    return;
                }

                moveToTrash("file", id);
            });
            break;
    }
}

function openMoveDialog(id, itemType, item) {
    pendingMove = {
        itemType: itemType,
        itemId: id,
        itemName: item && item.name ? item.name : "item",
        destinationGroupId: null,
        destinationFolderId: null
    };
    moveAnalysis = null;

    $("#moveSelectionSummary").text("Loading destinations...");
    $("#moveAnalysisPanel").html("<div class='move-empty'>Choose a destination to preview permissions.</div>");
    setMoveButtonEnabled(false);
    $("input[name='MovePermissionOption'][value='keep']").prop("checked", true);
    $(".cross-group-option").hide();
    $(".same-group-option").show();

    var existingTree = $("#moveDestinationTree").data("kendoTreeView");
    if (existingTree) {
        existingTree.destroy();
    }

    $("#moveDestinationTree").empty();
    moveWindow.title(itemType === "folder" ? "Move Folder" : "Move File");
    moveWindow.center().open();

    $.ajax({
        url: "/workspace/move-destinations",
        type: "GET",
        data: {
            itemType: itemType,
            itemId: id
        },
        success: function (nodes) {
            buildMoveDestinationTree(normalizeMoveNodes(nodes));
            $("#moveSelectionSummary").text("Select a destination for " + pendingMove.itemName + ".");
        },
        error: function () {
            $("#moveSelectionSummary").text("Unable to load move destinations.");
            kendo.alert("Unable to load move destinations.");
        }
    });
}

function normalizeMoveNodes(nodes) {
    return (nodes || []).map(function (node) {
        return {
            id: node.id ?? node.Id,
            text: node.text ?? node.Text,
            type: node.type ?? node.Type,
            groupId: node.groupId ?? node.GroupId,
            folderId: node.folderId ?? node.FolderId,
            expanded: node.expanded ?? node.Expanded,
            enabled: node.enabled ?? node.Enabled,
            items: normalizeMoveNodes(node.items ?? node.Items)
        };
    });
}

function buildMoveDestinationTree(nodes) {
    $("#moveDestinationTree").kendoTreeView({
        dataSource: new kendo.data.HierarchicalDataSource({
            data: nodes,
            schema: {
                model: {
                    id: "id",
                    children: "items"
                }
            }
        }),
        dataTextField: "text",
        template: function (item) {
            var data = item.item || item;
            var icon = data.type === "group" ? "k-i-folder-open" : "k-i-folder";
            var disabledClass = data.enabled === false ? " move-node-disabled" : "";
            var typeClass = data.type === "group" ? "group" : "folder";

            return "<span class='move-tree-node " + typeClass + disabledClass + "'>" +
                "<span class='k-icon k-font-icon " + icon + "'></span> " +
                kendo.htmlEncode(data.text || "-") +
                "</span>";
        },
        select: function (e) {
            var dataItem = this.dataItem(e.node);

            if (!dataItem || dataItem.enabled === false) {
                e.preventDefault();
                return;
            }

            if (pendingMove.itemType === "file" && dataItem.type === "group") {
                e.preventDefault();
                kendo.alert("Files must be moved into a folder.");
                return;
            }

            pendingMove.destinationGroupId = dataItem.groupId;
            pendingMove.destinationFolderId = dataItem.folderId || null;

            $("#moveSelectionSummary").text(
                "Destination: " + dataItem.text +
                (dataItem.type === "group" ? " root" : ""));

            analyzeMovePermissions(false);
        }
    });
}

function analyzeMovePermissions(autoAdjusted) {
    if (!pendingMove ||
        !pendingMove.destinationGroupId ||
        (pendingMove.itemType === "file" && !pendingMove.destinationFolderId)) {
        setMoveButtonEnabled(false);
        return;
    }

    var requestId = ++moveAnalysisRequestId;
    setMoveButtonEnabled(false);
    $("#moveAnalysisPanel").html("<div class='move-empty'>Analyzing permissions...</div>");

    $.ajax({
        url: "/workspace/analyze-move",
        type: "POST",
        data: buildMovePayload(),
        success: function (analysis) {
            if (requestId !== moveAnalysisRequestId) {
                return;
            }

            moveAnalysis = normalizeMoveAnalysis(analysis);

            if (!moveAnalysis.success) {
                $("#moveAnalysisPanel").html(
                    "<div class='move-empty'>" + kendo.htmlEncode(moveAnalysis.message || "Unable to analyze move.") + "</div>");
                return;
            }

            var reanalyzing = configureMovePermissionOptions(moveAnalysis, autoAdjusted);
            if (reanalyzing) {
                return;
            }

            renderMoveAnalysis(moveAnalysis);
            setMoveButtonEnabled(true);
        },
        error: function () {
            if (requestId !== moveAnalysisRequestId) {
                return;
            }

            $("#moveAnalysisPanel").html("<div class='move-empty'>Unable to analyze move permissions.</div>");
            setMoveButtonEnabled(false);
        }
    });
}

function configureMovePermissionOptions(analysis, autoAdjusted) {
    if (analysis.isCrossGroup) {
        $(".same-group-option").hide();
        $(".cross-group-option").show();

        if ($("input[name='MovePermissionOption']:checked").val() === "keep") {
            $("input[name='MovePermissionOption'][value='removeUnavailable']").prop("checked", true);

            if (!autoAdjusted) {
                analyzeMovePermissions(true);
                return true;
            }
        }

        return false;
    }

    $(".cross-group-option").hide();
    $(".same-group-option").show();

    var selected = $("input[name='MovePermissionOption']:checked").val();
    if (selected !== "keep" && selected !== "inherit") {
        $("input[name='MovePermissionOption'][value='keep']").prop("checked", true);

        if (!autoAdjusted) {
            analyzeMovePermissions(true);
            return true;
        }
    }

    return false;
}

function normalizeMoveAnalysis(analysis) {
    return {
        success: analysis.success ?? analysis.Success,
        message: analysis.message ?? analysis.Message,
        isCrossGroup: analysis.isCrossGroup ?? analysis.IsCrossGroup,
        itemName: analysis.itemName ?? analysis.ItemName,
        sourcePath: analysis.sourcePath ?? analysis.SourcePath,
        destinationPath: analysis.destinationPath ?? analysis.DestinationPath,
        foldersAffected: analysis.foldersAffected ?? analysis.FoldersAffected ?? 0,
        filesAffected: analysis.filesAffected ?? analysis.FilesAffected ?? 0,
        currentRoles: normalizeRoles(analysis.currentRoles ?? analysis.CurrentRoles),
        destinationRoles: normalizeRoles(analysis.destinationRoles ?? analysis.DestinationRoles),
        missingRoles: normalizeRoles(analysis.missingRoles ?? analysis.MissingRoles),
        afterMoveRoles: normalizeRoles(analysis.afterMoveRoles ?? analysis.AfterMoveRoles)
    };
}

function normalizeRoles(roles) {
    return (roles || []).map(function (role) {
        return {
            roleId: role.roleId ?? role.RoleId,
            roleName: role.roleName ?? role.RoleName
        };
    });
}

function renderMoveAnalysis(analysis) {
    var optionText = getSelectedMovePermissionText();
    var currentTitle = pendingMove.itemType === "file"
        ? "Current file roles"
        : "Current folder roles";
    var destinationTitle = pendingMove.destinationFolderId
        ? "Destination folder roles"
        : "Destination group roles";
    var afterTitle = "Roles that will apply after move";
    var missingBlock = analysis.missingRoles.length
        ? "<div class='move-role-list'><strong>Unavailable roles</strong>" + renderRolePills(analysis.missingRoles, true) + "</div>"
        : "<div class='move-role-list'><strong>Unavailable roles</strong><span class='move-empty'>None</span></div>";

    $("#moveAnalysisPanel").html(`
        <div class="move-option-note">Permission option: ${kendo.htmlEncode(optionText)}</div>
        <div><strong>${kendo.htmlEncode(analysis.itemName || pendingMove.itemName)}</strong></div>
        <div class="move-stats">
            <span>Source: ${kendo.htmlEncode(analysis.sourcePath || "-")}</span>
            <span>Destination: ${kendo.htmlEncode(analysis.destinationPath || "-")}</span>
            <span>Folders affected: ${analysis.foldersAffected}</span>
            <span>Files affected: ${analysis.filesAffected}</span>
        </div>
        <div class="move-analysis-grid">
            <div class="move-role-list">
                <strong>${currentTitle}</strong>
                ${renderRolePills(analysis.currentRoles, false)}
            </div>
            <div class="move-role-list">
                <strong>${destinationTitle}</strong>
                ${renderRolePills(analysis.destinationRoles, false)}
            </div>
            <div class="move-role-list">
                <strong>${afterTitle}</strong>
                ${renderRolePills(analysis.afterMoveRoles, false)}
            </div>
        </div>
        ${missingBlock}
    `);
}

function getSelectedMovePermissionText() {
    var value = $("input[name='MovePermissionOption']:checked").val();

    if (value === "keep") {
        return "Keep existing permissions";
    }

    if (value === "inherit") {
        return "Inherit destination permissions";
    }

    if (value === "merge") {
        return "Merge existing valid permissions with destination permissions";
    }

    return "Remove unavailable role permissions";
}

function renderRolePills(roles, removed) {
    if (!roles || roles.length === 0) {
        return "<span class='move-empty'>None</span>";
    }

    return roles.map(function (role) {
        var marker = removed ? "x " : "+ ";
        var cssClass = removed ? " removed" : "";
        return "<span class='move-role-pill" + cssClass + "'>" +
            marker + kendo.htmlEncode(role.roleName || "-") +
            "</span>";
    }).join("");
}

function buildMovePayload() {
    return {
        ItemType: pendingMove.itemType,
        ItemId: pendingMove.itemId,
        DestinationGroupId: pendingMove.destinationGroupId,
        DestinationFolderId: pendingMove.destinationFolderId,
        PermissionOption: $("input[name='MovePermissionOption']:checked").val(),
        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
    };
}

function submitMove() {
    if (!pendingMove || !moveAnalysis || !moveAnalysis.success) {
        kendo.alert("Please select a valid destination first.");
        return;
    }

    setMoveButtonEnabled(false);

    $.ajax({
        url: "/workspace/move",
        type: "POST",
        data: buildMovePayload(),
        success: function (result) {
            if (result.success) {
                moveWindow.close();
                loadFolderTree(currentGroupId);
                loadFolderContents(currentGroupId, currentFolderId);
                return;
            }

            kendo.alert(result.message || "Unable to move item.");
            setMoveButtonEnabled(true);
        },
        error: function () {
            kendo.alert("Unable to move item.");
            setMoveButtonEnabled(true);
        }
    });
}

function setMoveButtonEnabled(enabled) {
    var button = $("#btnConfirmMove").data("kendoButton");

    if (button) {
        button.enable(enabled);
        return;
    }

    $("#btnConfirmMove").prop("disabled", !enabled);
}
