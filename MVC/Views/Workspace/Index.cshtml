                    if (result.success) {

                        win.close();

                        location.reload();

                    }
                    else {

                        kendo.alert(result.message);

                    }

                },

                error: function () {

                    kendo.alert("Unable to update group.");

                }

            });

        });

    });

}

function deleteGroup(id) {

    kendo.confirm("Move this group to Trash?")
        .then(function () {

            moveToTrash("group", id);

        });

}

function openCreateFolderPopup(
    parentFolderId = null,
    parentFolderName = "Root",
    parentFolderPath = "/")
{
    if (!currentGroupId) {

        kendo.alert("Please select a group first.");

        return;
    }

    if (!folderWindow) {

        folderWindow = $("#folderWindow")
            .kendoWindow({

                title: "Create Folder",

                width: 650,

                modal: true,

                visible: false,

                resizable: false,

                draggable: true,

                actions: ["Close"]

            })
            .data("kendoWindow");
    }

    $("#createFolderForm")[0].reset();
    isEditFolder = false;

    $("#folderPermissionPropagationSection").hide();

    $("#SyncParents").prop("checked", false);
    $("#ApplyToChildren").prop("checked", false);
    $("#ApplyToFiles").prop("checked", false);
    $("#SyncGroup").prop("checked", false);

$("#FolderId").val("");

folderWindow.title("Create Folder");

$("#btnSaveFolder").text("Create Folder");

    $("#FolderGroupId").val(currentGroupId);

    $("#ParentFolderId").val(parentFolderId);

    $("#ParentFolderName").val(parentFolderName);

    $("#ParentFolderPath").val(parentFolderPath);

    if (!$("#FolderName").data("kendoTextBox")) {

        $("#FolderName").kendoTextBox();

    }

    if (!$("#FolderDescription").data("kendoTextArea")) {

        $("#FolderDescription").kendoTextArea({
            rows: 4
        });

    }

    if (!$("#FolderRoles").data("kendoMultiSelect")) {

        $("#FolderRoles").kendoMultiSelect({

            placeholder: "Select Roles..."

        });

    }

    $("#FolderRoles")
        .data("kendoMultiSelect")
        .value([]);

    folderWindow.center().open();
}

