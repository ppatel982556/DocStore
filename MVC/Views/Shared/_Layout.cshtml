@using Repositories.Models.ViewModels

@{
    var layout = ViewBag.Layout as LayoutVM;
}

@if (layout == null)
{
    <div class="alert alert-danger">
        Layout is NULL
    </div>
}
else
{
    <div style="display:none">
        Loaded @layout.User.FirstName
    </div>
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>
        @(ViewData["Title"] ?? "DocStore")
    </title>

    <!-- Fonts -->

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Bootstrap -->

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Kendo -->

    <link rel="stylesheet"
          href="~/lib/kendo/kendo.default-v2.min.css" />

    <!-- Layout -->

    <link rel="stylesheet"
          href="~/css/layout.css"
          asp-append-version="true" />

    <!-- Site -->

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

</head>

<body>

    <div class="app-container">

        <!-- Sidebar -->

        <aside class="sidebar">

            @await Html.PartialAsync("_Sidebar", layout)

        </aside>

        <!-- Main Area -->

        <div class="main-container">

            <!-- Topbar -->

            <header class="topbar">

                @await Html.PartialAsync("_Topbar", layout)

            </header>

            <!-- Content -->

            <main class="content">

                @RenderBody()

            </main>

        </div>

    </div>

    <!-- JQuery -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- Bootstrap -->

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Kendo -->

    <script src="~/lib/kendo/kendo.all.min.js"></script>

    <!-- Layout -->

    <script src="~/js/layout.js"
            asp-append-version="true"></script>

    <!-- Site -->

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
