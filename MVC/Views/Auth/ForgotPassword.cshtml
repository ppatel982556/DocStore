@model Repositories.Models.ViewModels.Auth.ForgotPasswordVm
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>DocStore | Forgot Password</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

    <style>

        :root{
            --brand-1:#4f46e5;
            --brand-2:#0ea5e9;
            --brand-3:#7c3aed;
            --ink:#1e2233;
            --muted:#6c7486;
            --card-radius:22px;
        }

        *{
            box-sizing:border-box;
        }

        html,body{
            height:100%;
        }

        body{
            margin:0;
            padding:0;
            font-family:'Segoe UI',system-ui,-apple-system,sans-serif;
            background:
                radial-gradient(circle at 15% 20%, rgba(255,255,255,.15), transparent 40%),
                radial-gradient(circle at 85% 80%, rgba(255,255,255,.12), transparent 45%),
                linear-gradient(135deg, var(--brand-1) 0%, var(--brand-3) 55%, var(--brand-2) 100%);
            background-size:200% 200%;
            animation:gradientShift 16s ease infinite;
        }

        @@keyframes gradientShift{
            0%{background-position:0% 50%;}
            50%{background-position:100% 50%;}
            100%{background-position:0% 50%;}
        }

        .auth-container{
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            padding:30px;
        }

        .auth-card{
            width:920px;
            max-width:100%;
            min-height:480px;
            background:#fff;
            border-radius:var(--card-radius);
            box-shadow:0 25px 60px rgba(20,20,50,.35);
            display:flex;
            overflow:hidden;
            transition: transform .25s ease;
        }

        .auth-card.loading{
            transform: scale(.98);
        }

        /* Left branding panel */
        .brand-panel{
            flex:0 0 42%;
            background:
                radial-gradient(circle at 30% 20%, rgba(255,255,255,.18), transparent 45%),
                linear-gradient(160deg, var(--brand-1), var(--brand-3));
            color:#fff;
            padding:48px 40px;
            display:flex;
            flex-direction:column;
            justify-content:space-between;
            position:relative;
            overflow:hidden;
        }

        .brand-panel::before{
            content:"";
            position:absolute;
            width:280px;
            height:280px;
            border-radius:50%;
            background:rgba(255,255,255,.08);
            top:-120px;
            right:-100px;
        }

        .brand-panel::after{
            content:"";
            position:absolute;
            width:180px;
            height:180px;
            border-radius:50%;
            background:rgba(255,255,255,.08);
            bottom:-70px;
            left:-60px;
        }

        .brand-logo{
            position:relative;
            z-index:1;
            margin-bottom:20px;
        }

        .brand-logo-img{
            width:220px;
            height:auto;
            display:block;
            object-fit:contain;
            filter:drop-shadow(0 8px 20px rgba(0,0,0,.18));
        }

        .brand-copy{
            position:relative;
            z-index:1;
        }

        .brand-copy h1{
            font-size:26px;
            font-weight:700;
            line-height:1.3;
            margin-bottom:14px;
        }

        .brand-copy p{
            font-size:14.5px;
            color:rgba(255,255,255,.85);
            line-height:1.6;
            max-width:320px;
        }

        .brand-foot{
            font-size:12.5px;
            color:rgba(255,255,255,.65);
            position:relative;
            z-index:1;
        }

        /* Right form panel */
        .form-panel{
            flex:1;
            padding:52px 48px;
            display:flex;
            flex-direction:column;
            justify-content:center;
        }

        .form-header{
            margin-bottom:28px;
        }

        .form-header .icon-badge{
            width:52px;
            height:52px;
            border-radius:14px;
            background:linear-gradient(135deg, rgba(79,70,229,.12), rgba(14,165,233,.12));
            display:flex;
            align-items:center;
            justify-content:center;
            margin-bottom:18px;
            font-size:20px;
            color:var(--brand-1);
        }

        .form-header h2{
            font-weight:700;
            color:var(--ink);
            margin-bottom:6px;
            font-size:24px;
        }

        .form-header p{
            color:var(--muted);
            font-size:14px;
            margin:0;
            line-height:1.5;
        }

        #validation-success{
            margin-bottom:16px;
        }

        #validation-success .alert{
            border-radius:10px;
            font-size:13.5px;
            padding:10px 14px;
        }

        .form-label{
            font-weight:600;
            font-size:13px;
            color:var(--ink);
            margin-bottom:6px;
        }

        .form-control{
            border-radius:10px;
            border:1.5px solid #e3e6ef;
            padding:11px 14px;
            font-size:14.5px;
            transition:border-color .15s ease, box-shadow .15s ease;
        }

        .form-control:focus{
            border-color:var(--brand-1);
            box-shadow:0 0 0 3px rgba(79,70,229,.12);
            outline:none;
        }

        .form-control.is-invalid{
            border-color:#dc3545;
        }

        .btn-brand{
            width:100%;
            background:linear-gradient(135deg, var(--brand-1), var(--brand-3));
            border:none;
            border-radius:10px;
            padding:12px 18px;
            font-weight:600;
            font-size:14.5px;
            color:#fff;
            box-shadow:0 8px 18px rgba(79,70,229,.3);
            transition:transform .15s ease, box-shadow .15s ease;
            margin-top:8px;
        }

        .btn-brand:hover{
            transform:translateY(-1px);
            box-shadow:0 10px 22px rgba(79,70,229,.4);
            color:#fff;
        }

        .back-link{
            display:inline-flex;
            align-items:center;
            gap:6px;
            margin-top:22px;
            font-size:13.5px;
            color:var(--muted);
            text-decoration:none;
            font-weight:600;
        }

        .back-link:hover{
            color:var(--brand-1);
        }

        @@media (max-width:768px){

            .auth-card{
                flex-direction:column;
                width:100%;
            }

            .brand-panel{
                flex:none;
                padding:32px 30px;
            }

            .brand-copy h1{
                font-size:22px;
            }

            .form-panel{
                padding:36px 30px;
            }

        }

        /* Loader */
        .login-loader{
            position: fixed;
            inset: 0;

            display: flex;
            justify-content: center;
            align-items: center;

            background: rgba(30,34,51,.35);
            backdrop-filter: blur(6px);

            z-index: 99999;

            opacity: 0;
            visibility: hidden;
            pointer-events: none;

            transition: opacity .25s ease,
                        visibility .25s ease;
        }

        .login-loader.show{
            opacity: 1;
            visibility: visible;
            pointer-events: all;
        }

        .loader-card{
            background:#fff;
            border-radius:22px;
            padding:42px 50px;
            text-align:center;
            box-shadow:0 25px 60px rgba(20,20,50,.35);
            min-width:300px;
            animation:loaderPopIn .35s cubic-bezier(.34,1.56,.64,1);
        }

        @@keyframes loaderPopIn{
            0%{transform:scale(.85);opacity:0;}
            100%{transform:scale(1);opacity:1;}
        }

        .loader-logo-wrap{
            position:relative;
            width:92px;
            height:92px;
            margin:0 auto 22px;
            display:flex;
            align-items:center;
            justify-content:center;
        }

        .loader-ring{
            position:absolute;
            inset:0;
            border-radius:50%;
            border:3px solid #e3e6ef;
            border-top-color:var(--brand-1);
            border-right-color:var(--brand-2);
            animation:loaderSpin 1s linear infinite;
        }

        .loader-pulse{
            position:absolute;
            inset:0;
            border-radius:50%;
            background:linear-gradient(135deg, var(--brand-1), var(--brand-2));
            opacity:.15;
            animation:loaderPulse 1.6s ease-out infinite;
        }

        @@keyframes loaderSpin{
            to{transform:rotate(360deg);}
        }

        @@keyframes loaderPulse{
            0%{transform:scale(.7);opacity:.25;}
            70%{transform:scale(1.15);opacity:0;}
            100%{transform:scale(1.15);opacity:0;}
        }

        .loader-logo-img{
            width:52px;
            height:52px;
            object-fit:contain;
            position:relative;
            z-index:1;
            filter:drop-shadow(0 4px 10px rgba(79,70,229,.25));
        }

        .loader-card h5{
            margin:0;
            font-weight:700;
            color:var(--ink);
            font-size:17px;
            letter-spacing:.2px;
        }

        .loader-card p{
            margin-top:8px;
            color:var(--muted);
            font-size:13.5px;
        }

        .loader-dots span{
            display:inline-block;
            width:6px;
            height:6px;
            border-radius:50%;
            background:var(--brand-1);
            margin:0 3px;
            opacity:.3;
            animation:loaderDots 1.2s ease-in-out infinite;
        }

        .loader-dots span:nth-child(2){animation-delay:.15s;}
        .loader-dots span:nth-child(3){animation-delay:.3s;}

        @@keyframes loaderDots{
            0%,80%,100%{opacity:.3;transform:translateY(0);}
            40%{opacity:1;transform:translateY(-3px);}
        }

    </style>

</head>

<div id="loginLoader" class="login-loader">

    <div class="loader-card">

        <div class="loader-logo-wrap">
            <div class="loader-pulse"></div>
            <div class="loader-ring"></div>
            <img src="~/images/logo/DocStore(Small).png" class="loader-logo-img" />
        </div>

        <h5>Sending reset link</h5>

        <p>Please wait a moment
            <span class="loader-dots"><span></span><span></span><span></span></span>
        </p>

    </div>

</div>

<body>

<div class="auth-container">

    <div class="auth-card">

        <div class="brand-panel">

            <div class="brand-logo">
                <img src="~/images/logo/DocStore(Main).png" class="brand-logo-img" />
            </div>

            <div class="brand-copy">
                <h1>Forgot your<br/>password?</h1>
                <p>No worries. Enter the email tied to your account and we'll send you a link to get back in.</p>
            </div>

            <div class="brand-foot">
                &copy; @DateTime.Now.Year DocStore. All rights reserved.
            </div>

        </div>

        <div class="form-panel">

            <div class="form-header">
                <div class="icon-badge">
                    <i class="fa-solid fa-key"></i>
                </div>
                <h2>Reset your password</h2>
                <p>Enter your registered email and we'll send a secure link to reset your password.</p>
            </div>

            <div id="validation-success"></div>

            <form id="ForgotPasswordForm" asp-action="ForgotPassword" asp-controller="Auth" method="post" novalidate>

                <div class="mb-3">

    <label asp-for="Email" class="form-label"></label>

    <input asp-for="Email"
           class="form-control"
           placeholder="Enter your registered email" />

    <span asp-validation-for="Email"
          class="text-danger"></span>
          <span id="emailError"
      class="text-danger"
      style="display:none;">
    Please enter a valid email.
</span>

</div>

                <button type="submit" class="btn-brand">
                    Send Reset Link
                </button>

                <a href="@Url.Action("Login", "Auth")" class="back-link">
                    <i class="fa-solid fa-arrow-left"></i> Back to sign in
                </a>

            </form>

        </div>

    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>

$(function () {

    const form = $("#ForgotPasswordForm");
    const validationBox = $("#validation-success");

    form.on("submit", function (e) {

        e.preventDefault();

        validationBox.empty();

        // Show Loader
        $(".auth-card").addClass("loading");
        $("#loginLoader").addClass("show");

        form.find("input,button").prop("disabled", true);
        $.ajax({

            url: form.attr("action"),

            type: "POST",

            data: {
    Email: $("#Email").val()
},

            success: function (response) {

                validationBox.html(
                    `<div class="alert alert-success">
                        ${response.message}
                    </div>`
                );

                form.trigger("reset");

            },

            error: function (xhr) {

                let message = "Something went wrong.";

                if (xhr.responseJSON && xhr.responseJSON.message)
                    message = xhr.responseJSON.message;

                validationBox.html(
                    `<div class="alert alert-danger">
                        ${message}
                    </div>`
                );

            },

            complete: function () {

                // Hide Loader (runs on both success & error)
                $(".auth-card").removeClass("loading");
                $("#loginLoader").removeClass("show");

                form.find("input,button").prop("disabled", false);

            }

        });

    });

});

</script>

</body>

</html>
